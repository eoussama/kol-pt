{
  "name": "kol-pt",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "description": "KOL Patreon Tracker is a Chromium extension and Edge addon that helps you track KingOfLightning (KOL) reactions on Patreon. KOL is an Anime/Manga YouTuber who mostly does One Piece content and other reactions and theories.",
  "author": "EOussama",
  "license": "ISC",
  "homepage": "https://github.com/EOussama/kol-pt#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EOussama/kol-pt.git"
  },
  "bugs": {
    "url": "https://github.com/EOussama/kol-pt/issues"
  },
  "keywords": ["chrome-extension", "patreon", "kol", "edge-addon"],
  "scripts": {
    "postinstall": "pnpm run env",
    "env": "cp .env ./src/config/.env 2>/dev/null || true",
    "start": "pnpm run env && vite",
    "build": "pnpm run env && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "clean": "rm -rf build",
    "lint": "pnpm exec dx lint",
    "lint:fix": "pnpm exec dx lint --fix"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eoussama/core": "^0.0.4",
    "@eoussama/firemitt": "^0.1.5",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vimeo/player": "^2.30.2",
    "base-64": "^1.0.0",
    "firebase": "^12.15.0",
    "millify": "^6.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "utf8": "^3.0.0",
    "web-vitals": "^5.3.0",
    "zustand": "^5.0.14"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eoussama/dx": "^0.0.4",
    "@types/base-64": "^1.0.2",
    "@types/chrome": "^0.2.0",
    "@types/serviceworker": "^0.0.197",
    "@types/utf8": "^3.0.3",
    "@types/vimeo__player": "^2.18.3",
    "@vitejs/plugin-react": "^4.5.2",
    "firebase-tools": "^14.27.0",
    "jsdom": "^26.1.0",
    "vite": "^6.3.5",
    "vite-plugin-web-extension": "^4.1.2",
    "vitest": "^3.2.4"
  }
}
